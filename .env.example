# ArtimesOne environment variables.
# Copy this file to `.env` and fill in the values you want.
# All variables are optional — the app will boot with zero env vars set.
# Missing API keys disable features; they never crash startup.

# --- Core ------------------------------------------------------------------

# Directory for the SQLite database. Created on first run.
ARTIMESONE_DATA_DIR=./data

# Directory for transcripts, summaries, and rollups (md files). Created on first run.
ARTIMESONE_CONTENT_DIR=./content

# Web server bind host.
ARTIMESONE_HOST=127.0.0.1

# Web server port.
ARTIMESONE_PORT=8000

# --- LLM (OpenAI / OpenAI-compatible) --------------------------------------

# OpenAI API key. Read by the openai SDK natively (no ARTIMESONE_ prefix).
OPENAI_API_KEY=

# Optional base URL override (e.g., for a local OpenAI-compatible server).
OPENAI_BASE_URL=

# Model used for summarization.
ARTIMESONE_SUMMARY_MODEL=openai:gpt-4o-mini

# Model used for the chat agent.
ARTIMESONE_CHAT_MODEL=openai:gpt-4o

# --- YouTube ---------------------------------------------------------------

# YouTube Data API v3 key. Required to enable the YouTube collector.
ARTIMESONE_YOUTUBE_API_KEY=

# Skip videos longer than this many minutes (Phase 1: avoid surprise Apify spend).
ARTIMESONE_MAX_VIDEO_DURATION_MINUTES=60

# --- Apify -----------------------------------------------------------------

# Apify API token. Read by the Apify SDK natively (no ARTIMESONE_ prefix).
APIFY_TOKEN=

# Apify actor used to fetch YouTube transcripts.
ARTIMESONE_APIFY_YOUTUBE_ACTOR=streamers/youtube-scraper

# --- Telegram --------------------------------------------------------------

# Bot token from @BotFather. Required to enable the Telegram channel.
ARTIMESONE_TELEGRAM_BOT_TOKEN=

# Whitelisted chat ID. Telegram messages from any other chat are ignored.
ARTIMESONE_TELEGRAM_ALLOWED_CHAT_ID=
